# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-only, for AI pipeline / seed scripts — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq API (server-only — used by AI pipeline)
GROQ_API_KEY=your-groq-api-key

# Mapbox (client-side — used for admin map)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
